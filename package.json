{
  "name": "spend-back-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api-gateway",
    "account-service",
    "file-service",
    "geolocalisation-service",
    "user-service",
    "ws-service"
  ],
  "scripts": {
    "install:all": "yarn install",
    "dev:all": "npx concurrently -c \"cyan,magenta,yellow,green,blue\" -n \"user,ws,account,file,geoloc\" \"yarn workspace user-service dev\" \"yarn workspace ws-service dev\" \"yarn workspace account-service dev\" \"yarn workspace file-service dev\" \"yarn workspace geolocalisation-service dev\"",
    "test:all": "yarn workspaces foreach -A run test",
    "lint:all": "yarn workspaces foreach -A run lint"
  },
  "dependencies": {
    "@clement.pasteau/account-service": "0.4.4",
    "@clement.pasteau/contracts": "1.1.0",
    "@clement.pasteau/shared": "1.1.0",
    "@clement.pasteau/user-service": "0.4.2"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
}
